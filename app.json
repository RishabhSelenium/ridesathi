{
  "expo": {
    "name": "ThrottleUp",
    "slug": "throttleup",
    "scheme": "throttleup",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/litelogo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./src/assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
        "image": "./src/assets/logo.png",
        "backgroundColor": "#020617"
      }
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.reinagain.throttleup",
      "icon": {
        "light": "./src/assets/litelogo.png",
        "dark": "./src/assets/darklogo.png"
      }
    },
    "android": {
      "package": "com.reinagain.throttleup",
      "softwareKeyboardLayoutMode": "resize",
      "googleServicesFile": "./android/app/google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/litelogo.png",
        "backgroundColor": "#ffffff",
        "monochromeImage": "./src/assets/darklogo.png"
      }
    },
    "updates": {
      "enabled": false
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow ThrottleUp to use your location to auto-update your city."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow ThrottleUp to access your photos so you can upload profile, squad, and bike images."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./src/assets/notification-icon.png",
          "color": "#F97316",
          "sounds": [
            "./src/assets/Ride_notification.mp3",
            "./src/assets/msg_notification.mp3"
          ]
        }
      ]
    ],
    "web": {
      "bundler": "metro"
    }
  }
}
