rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isNumber(value) {
      return value is int || value is float;
    }

    function validUser(data, userId) {
      return data.keys().hasAll([
          'id',
          'name',
          'garage',
          'bikeType',
          'city',
          'style',
          'experience',
          'distance',
          'isPro',
          'avatar',
          'verified',
          'typicalRideTime',
          'friends',
          'friendRequests'
        ]) &&
        data.keys().hasOnly([
          'id',
          'phoneNumber',
          'name',
          'handle',
          'firstName',
          'lastName',
          'fullName',
          'garage',
          'bikeType',
          'city',
          'style',
          'experience',
          'distance',
          'isPro',
          'avatar',
          'verified',
          'typicalRideTime',
          'sosNumber',
          'sosContacts',
          'dob',
          'bloodGroup',
          'profileComplete',
          'bikePhotosByName',
          'friends',
          'friendRequests',
          'blockedUserIds',
          'expoPushTokens'
        ]) &&
        data.id == userId &&
        (data.phoneNumber == null || data.phoneNumber is string) &&
        data.name is string &&
        (data.handle == null || data.handle is string) &&
        data.garage is list &&
        data.bikeType is string &&
        data.city is string &&
        data.style is string &&
        data.experience is string &&
        data.distance is string &&
        data.isPro is bool &&
        data.avatar is string &&
        data.verified is bool &&
        data.typicalRideTime is string &&
        (data.firstName == null || data.firstName is string) &&
        (data.lastName == null || data.lastName is string) &&
        (data.fullName == null || data.fullName is string) &&
        (data.sosNumber == null || data.sosNumber is string) &&
        (data.sosContacts == null || data.sosContacts is list) &&
        (data.dob == null || data.dob is string) &&
        (data.bloodGroup == null || data.bloodGroup is string) &&
        (data.profileComplete == null || data.profileComplete is bool) &&
        (data.bikePhotosByName == null || data.bikePhotosByName is map) &&
        data.friends is list &&
        data.friendRequests is map &&
        data.friendRequests.keys().hasOnly(['sent', 'received']) &&
        data.friendRequests.sent is list &&
        data.friendRequests.received is list &&
        (data.blockedUserIds == null || data.blockedUserIds is list) &&
        (data.expoPushTokens == null || data.expoPushTokens is list);
    }

    function validRide(data, rideId) {
      return data.id == rideId &&
        data.creatorId is string &&
        data.creatorName is string &&
        data.creatorAvatar is string &&
        data.type is string &&
        data.title is string &&
        data.route is string &&
        data.date is string &&
        data.startTime is string &&
        isNumber(data.maxParticipants) &&
        data.maxParticipants >= 1 &&
        data.currentParticipants is list &&
        data.requests is list &&
        data.city is string &&
        data.visibility is list &&
        data.visibility.size() > 0 &&
        data.createdAt is string;
    }

    function canSelfJoinOpenRide() {
      return (
          resource.data.joinPermission == 'anyone' ||
          (
            !(resource.data.joinPermission is string) &&
            request.resource.data.joinPermission == 'anyone'
          )
        ) &&
        (
          (resource.data.requests is list && request.resource.data.requests == resource.data.requests) ||
          (!(resource.data.requests is list) && request.resource.data.requests is list && request.resource.data.requests.size() == 0)
        ) &&
        !resource.data.currentParticipants.hasAny([request.auth.uid]) &&
        request.resource.data.currentParticipants.hasAll(resource.data.currentParticipants) &&
        request.resource.data.currentParticipants.hasAll([request.auth.uid]) &&
        request.resource.data.currentParticipants.size() == resource.data.currentParticipants.size() + 1 &&
        request.resource.data.currentParticipants.size() <= resource.data.maxParticipants;
    }

    function validHelpPost(data, postId) {
      return data.keys().hasAll([
          'id',
          'creatorId',
          'creatorName',
          'creatorAvatar',
          'title',
          'description',
          'bikeModel',
          'category',
          'resolved',
          'upvotes',
          'replies',
          'createdAt'
        ]) &&
        data.keys().hasOnly([
          'id',
          'creatorId',
          'creatorName',
          'creatorAvatar',
          'title',
          'description',
          'bikeModel',
          'category',
          'resolved',
          'upvotes',
          'image',
          'replies',
          'createdAt'
        ]) &&
        data.id == postId &&
        data.creatorId is string &&
        data.creatorName is string &&
        data.creatorAvatar is string &&
        data.title is string &&
        data.description is string &&
        data.bikeModel is string &&
        data.category is string &&
        data.resolved is bool &&
        isNumber(data.upvotes) &&
        (data.image == null || data.image is string) &&
        data.replies is list &&
        data.createdAt is string;
    }

    function validSquad(data, squadId) {
      return data.keys().hasAll([
          'id',
          'name',
          'description',
          'creatorId',
          'members',
          'adminIds',
          'avatar',
          'city',
          'rideStyles',
          'joinPermission',
          'joinRequests',
          'createdAt'
        ]) &&
        data.keys().hasOnly([
          'id',
          'name',
          'description',
          'creatorId',
          'members',
          'adminIds',
          'avatar',
          'city',
          'rideStyle',
          'rideStyles',
          'joinPermission',
          'joinRequests',
          'createdAt'
        ]) &&
        data.id == squadId &&
        data.name is string &&
        data.description is string &&
        data.creatorId is string &&
        data.members is list &&
        data.adminIds is list &&
        data.avatar is string &&
        data.city is string &&
        (data.rideStyle == null || data.rideStyle is string) &&
        data.rideStyles is list &&
        data.rideStyles.size() > 0 &&
        (data.joinPermission == 'anyone' || data.joinPermission == 'request_to_join') &&
        data.joinRequests is list &&
        data.createdAt is string;
    }

    function validModerationReport(data, reportId) {
      return data.keys().hasAll([
          'id',
          'reporterId',
          'targetType',
          'targetId',
          'reason',
          'createdAt'
        ]) &&
        data.keys().hasOnly([
          'id',
          'reporterId',
          'targetType',
          'targetId',
          'reason',
          'details',
          'createdAt'
        ]) &&
        data.id == reportId &&
        data.reporterId is string &&
        (data.targetType == 'user' || data.targetType == 'ride' || data.targetType == 'helpPost') &&
        data.targetId is string &&
        data.reason is string &&
        (data.details == null || data.details is string) &&
        data.createdAt is string;
    }

    match /users/{userId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() &&
        request.auth.uid == userId &&
        validUser(request.resource.data, userId);

      allow update: if isSignedIn() &&
        validUser(request.resource.data, userId) &&
        (
          request.auth.uid == userId ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friends', 'friendRequests'])
        );

      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    match /rides/{rideId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() &&
        validRide(request.resource.data, rideId) &&
        request.resource.data.creatorId == request.auth.uid;

      allow update: if isSignedIn() &&
        request.resource.data.id == resource.data.id &&
        request.resource.data.creatorId == resource.data.creatorId &&
        request.resource.data.createdAt == resource.data.createdAt &&
        (
          (
            request.auth.uid == resource.data.creatorId &&
            validRide(request.resource.data, rideId)
          ) ||
          (
            request.auth.uid == resource.data.creatorId &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentParticipants', 'requests']) &&
            request.resource.data.currentParticipants is list &&
            request.resource.data.requests is list
          ) ||
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['requests']) &&
            request.resource.data.currentParticipants == resource.data.currentParticipants &&
            request.resource.data.requests is list
          ) ||
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'currentParticipants',
              'requests',
              'joinPermission'
            ]) &&
            request.resource.data.currentParticipants is list &&
            request.resource.data.requests is list &&
            canSelfJoinOpenRide()
          )
        );

      allow delete: if isSignedIn() && resource.data.creatorId == request.auth.uid;
    }

    match /helpPosts/{postId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() &&
        validHelpPost(request.resource.data, postId) &&
        request.resource.data.creatorId == request.auth.uid;

      allow update: if isSignedIn() &&
        validHelpPost(request.resource.data, postId) &&
        request.resource.data.id == resource.data.id &&
        request.resource.data.creatorId == resource.data.creatorId &&
        request.resource.data.createdAt == resource.data.createdAt &&
        (
          request.auth.uid == resource.data.creatorId ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes', 'replies'])
        );

      allow delete: if isSignedIn() && resource.data.creatorId == request.auth.uid;
    }

    match /squads/{squadId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() &&
        validSquad(request.resource.data, squadId) &&
        request.resource.data.creatorId == request.auth.uid;

      allow update: if isSignedIn() &&
        validSquad(request.resource.data, squadId) &&
        request.resource.data.id == resource.data.id &&
        request.resource.data.creatorId == resource.data.creatorId &&
        request.resource.data.createdAt == resource.data.createdAt &&
        (
          request.auth.uid == resource.data.creatorId ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'joinRequests'])
        );

      allow delete: if isSignedIn() && resource.data.creatorId == request.auth.uid;
    }

    match /moderationReports/{reportId} {
      allow create: if isSignedIn() &&
        validModerationReport(request.resource.data, reportId) &&
        request.resource.data.reporterId == request.auth.uid;

      allow read, update, delete: if false;
    }
  }
}
